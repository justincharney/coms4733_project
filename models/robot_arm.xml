<mujoco model="robot_arm">
  <compiler angle="degree" coordinate="local"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"
              reflectance=".2"/>
    <material name="arm_material" rgba="0.7 0.7 0.9 1"/>
    <material name="gripper_material" rgba="0.9 0.5 0.5 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
    <geom name="floor" type="plane" size="2 2 0.1" material="grid"/>

    <!-- Base -->
    <body name="base" pos="0 0 0.1">
      <geom name="base" type="cylinder" size="0.1 0.05" rgba="0.3 0.3 0.3 1"/>

      <!-- Shoulder joint -->
      <body name="link1" pos="0 0 0.05">
        <joint name="shoulder" type="hinge" axis="0 0 1" range="-180 180" damping="1"/>
        <geom name="link1" type="capsule" fromto="0 0 0 0 0 0.3" size="0.04" material="arm_material"/>

        <!-- Elbow joint -->
        <body name="link2" pos="0 0 0.3">
          <joint name="elbow" type="hinge" axis="0 1 0" range="-150 150" damping="1"/>
          <geom name="link2" type="capsule" fromto="0 0 0 0 0 0.3" size="0.035" material="arm_material"/>

          <!-- End effector -->
          <body name="end_effector" pos="0 0 0.3">
            <geom name="ee_sphere" type="sphere" size="0.03" rgba="1 0.2 0.2 1"/>

            <!-- Simple gripper fingers -->
            <body name="finger_left" pos="0.03 0 0">
              <joint name="gripper_left" type="slide" axis="1 0 0" range="0 0.04" damping="0.1"/>
              <geom name="finger_left" type="box" size="0.01 0.015 0.05"
                    material="gripper_material" pos="0.01 0 -0.05"/>
            </body>

            <body name="finger_right" pos="-0.03 0 0">
              <joint name="gripper_right" type="slide" axis="-1 0 0" range="0 0.04" damping="0.1"/>
              <geom name="finger_right" type="box" size="0.01 0.015 0.05"
                    material="gripper_material" pos="-0.01 0 -0.05"/>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Target object to manipulate -->
    <body name="target" pos="0.3 0.3 0.1">
      <joint name="target_free" type="free"/>
      <geom name="target" type="box" size="0.03 0.03 0.03" rgba="0.2 0.8 0.2 1" mass="0.1"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="shoulder_motor" joint="shoulder" gear="20" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="elbow_motor" joint="elbow" gear="15" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="gripper_left_motor" joint="gripper_left" gear="5" ctrllimited="true" ctrlrange="-2 2"/>
    <motor name="gripper_right_motor" joint="gripper_right" gear="5" ctrllimited="true" ctrlrange="-2 2"/>
  </actuator>

  <sensor>
    <jointpos name="shoulder_pos" joint="shoulder"/>
    <jointpos name="elbow_pos" joint="elbow"/>
    <jointvel name="shoulder_vel" joint="shoulder"/>
    <jointvel name="elbow_vel" joint="elbow"/>
  </sensor>
</mujoco>
